# Vite environment variables must be prefixed with VITE_ to be exposed to the browser.
# Copy this file to .env and fill in values for local development.

# API base URL — only needed if NOT using the Vite dev proxy (vite.config.js proxies /api to localhost:3001 by default)
# VITE_API_URL=http://localhost:3001

# App display name (optional override)
# VITE_APP_NAME=MCP CuramTools
