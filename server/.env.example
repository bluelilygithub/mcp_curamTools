# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mcp_curamtools

# App
PORT=3002
NODE_ENV=development
APP_URL=http://localhost:5174
APP_NAME=MCP CuramTools
ORG_NAME=My Organisation

# Platform template org for model/settings inheritance (default: 1)
PLATFORM_ORG_ID=1

# App plugins (folder names under server/apps/). Defaults: diamond-plate,engineering
# PLATFORM_PLUGINS=diamond-plate,engineering
# EXTRA_PLUGINS=starter

# Admin seed (auto-created on startup if not exists)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (chat + RAG embeddings when embedding model is Gemini)
GEMINI_API_KEY=

# OpenAI (optional — RAG embeddings when embedding model is text-embedding-3-small)
OPENAI_API_KEY=

# Email — MailChannels (primary)
MAIL_CHANNEL_API_KEY=
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=MCP CuramTools

# Email — SMTP fallback (used when MAIL_CHANNEL_API_KEY is not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# AWS S3 (file storage — optional, enables Doc Extractor storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=ap-southeast-2

# File intake antivirus scanning (optional; requires a reachable clamd daemon)
FILE_INTAKE_CLAMAV_ENABLED=false
FILE_INTAKE_CLAMAV_HOST=127.0.0.1
FILE_INTAKE_CLAMAV_PORT=3310
FILE_INTAKE_CLAMAV_TIMEOUT_MS=5000
