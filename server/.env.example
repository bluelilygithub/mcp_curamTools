# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mcp_curamtools

# App
PORT=3002
NODE_ENV=development
APP_URL=http://localhost:5174
APP_NAME=MCP CuramTools
ORG_NAME=My Organisation

# Admin seed (auto-created on startup if not exists)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Email — MailChannels (primary)
MAIL_CHANNEL_API_KEY=
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=MCP CuramTools

# Email — SMTP fallback (used when MAIL_CHANNEL_API_KEY is not set)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
